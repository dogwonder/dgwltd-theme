{
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#14D5DE",
					"name": "Primary"
				},
				{
					"slug": "secondary",
					"color": "#FF00A6",
					"name": "Secondary"
				},
				{
					"slug": "foreground",
					"color": "#000000",
					"name": "Foreground"
				},
				{
					"slug": "background",
					"color": "#ffffff",
					"name": "Background"
				}
			]
		},
		"custom": {
			"spacing": {
				"baseline": "16px",
				"extra-small": "min(8px, 1.6vw)",
				"small": "min(16px, 3.2vw)",
				"medium": "min(32px, 6.4vw)",
				"large": "min(48px, 12.8vw)",
				"extra-large": "min(96px, 25.6vw)",
				"gap": {
					"horizontal": "clamp( calc( 1.5 * var( --wp--custom--spacing--baseline ) ), 2.222vw, calc( 2 * var( --wp--custom--spacing--baseline ) ) )",
					"vertical": "clamp( calc( 1.5 * var( --wp--custom--spacing--baseline ) ), 3.333vw, calc( 3 * var( --wp--custom--spacing--baseline ) ) )"
				},
				"gutter": "clamp( calc( 2 * var( --wp--custom--spacing--baseline ) ), 6.666vw, calc( 4 * var( --wp--custom--spacing--baseline ) ) )",
				"outer": "var( --wp--custom--spacing--gutter )"
			},
			"typography": {
				"letter-spacing": {
					"body": "-0.01em",
					"heading": "-0.02em",
					"gigantic": "0.01em",
					"uppercase": "0"
				},
				"line-height": {
					"body": "1.5",
					"headings": {
						"gigantic": 1.05,
						"large": 1.15,
						"small": 1.25
					}
				}
			}
		},
		"spacing": {
			"units": [
				"%",
				"px",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"dropCap": false,
			"fontFamilies": [
				{
					"fontFamily": "-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Oxygen-Sans,Ubuntu,Cantarell,\"Helvetica Neue\",sans-serif",
					"name": "System Font",
					"slug": "system-font"
				},
				{
					"fontFamily": "\"Söhne Halbfett\", sans-serif",
					"name": "Söhne Halbfett",
					"slug": "soehne-halbfett"
				}, 
				{
					"fontFamily": "\"Söhne Kraftig\", sans-serif",
					"name": "Söhne Kraftig",
					"slug": "soehne-kraftig"
				}
			],
			"fontSizes": [
				{
					"name": "Tiny",
					"size": "0.75rem",
					"slug": "tiny"
				},
				{
					"name": "Small",
					"size": "1rem",
					"slug": "small"
				},
				{
					"name": "Normal",
					"size": "1.125rem",
					"slug": "normal"
				},
				{
					"name": "Medium",
					"size": "1.333rem",
					"fluidSize": {
						"min": "1.125rem",
						"max": "1.333rem"
					},
					"slug": "medium"
				},
				{
					"name": "Large",
					"size": "1.777rem",
					"fluidSize": {
						"min": "1.333rem",
						"max": "1.777rem"
					},
					"slug": "large"
				},
				{
					"name": "Extra Large",
					"size": "2.369rem",
					"fluidSize": {
						"min": "1.777rem",
						"max": "2.369rem"
					},
					"slug": "extra-large"
				},
				{
					"name": "Huge",
					"size": "3.157rem",
					"fluidSize": {
						"min": "2.369rem",
						"max": "3.157rem"
					},
					"slug": "huge"
				},
				{
					"name": "Massive",
					"size": "4.209rem",
					"fluidSize": {
						"min": "3.157rem",
						"max": "4.209rem"
					},
					"slug": "massive"
				}
			]
		},
		"layout": {
			"contentSize": "1120px"
		}
	},
	"styles": {
		"blocks": {
			"core/buttons": {
				"spacing": {
					"blockGap": "1em"
				}
			},
			"core/button": {
				"border": {
					"radius": "4px"
				},
				"color": {
					"background": "var(--wp--preset--color--secondary)",
					"text": "var(--wp--preset--color--background)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "bold"
				}
			},
			"core/pullquote": {
				"border": {
					"width": "1px 0"
				}
			},
			"core/quote": {
				"border": {
					"width": "1px"
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--foreground)"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--soehne-halbfett)",
					"fontSize": "var(--wp--preset--font-size--massive)", 
					"fontWeight": "normal",
					"lineHeight": "var(--wp--custom--typography--line-height--headings--gigantic)",
					"letterSpacing": "var(--wp--custom--typography--letter-spacing--gigantic)"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--soehne-halbfett)",
					"fontSize": "var(--wp--preset--font-size--huge)", 
					"fontWeight": "normal",
					"lineHeight": "var(--wp--custom--typography--line-height--headings--gigantic)",
					"letterSpacing": "var(--wp--custom--typography--letter-spacing--gigantic)"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--soehne-kraftig)",
					"fontSize": "var(--wp--preset--font-size--extra-large)", 
					"fontWeight": "normal",
					"lineHeight": "var(--wp--custom--typography--line-height--small)",
					"letterSpacing": "var(--wp--custom--typography--letter-spacing--heading)"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--soehne-kraftig)",
					"fontSize": "var(--wp--preset--font-size--large)", 
					"fontWeight": "normal",
					"lineHeight": "var(--wp--custom--typography--line-height--body)",
					"letterSpacing": "var(--wp--custom--typography--letter-spacing--heading)"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--soehne-kraftig)",
					"fontSize": "var(--wp--preset--font-size--medium)", 
					"fontWeight": "normal",
					"lineHeight": "var(--wp--custom--typography--line-height--body)",
					"letterSpacing": "var(--wp--custom--typography--letter-spacing--heading)"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--soehne-kraftig)",
					"fontSize": "var(--wp--preset--font-size--medium)", 
					"fontWeight": "normal",
					"lineHeight": "var(--wp--custom--typography--line-height--body)",
					"letterSpacing": "var(--wp--custom--typography--letter-spacing--heading)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--foreground)"
				}
			}
		},
		"spacing": {
			"blockGap": "var(--wp--custom--spacing--medium)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system-font)",
			"fontSize": "var(--wp--preset--font-size--medium)", 
			"fontWeight": "500",
			"letterSpacing": "var(--wp--custom--typography--letter-spacing--body)",
			"lineHeight": "var(--wp--custom--typography--line-height--body)"
		}
	}
}
